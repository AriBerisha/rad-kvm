[Unit]
Description=q6a-kvm control plane (web UI + HID input bridge)
After=network-online.target q6a-kvm-streamer.service q6a-kvm-gadget.service
Wants=q6a-kvm-streamer.service q6a-kvm-gadget.service

[Service]
# Needs root: writes the HID gadget (/dev/hidg*) and the 0600 auth store.
ExecStart=/usr/local/bin/qkvm
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
